  to { left: -120px; }
}

JavaScript
function createMovingItem(areaId, imageList) {
  const item = document.createElement("div");

  item.className = "item";
  item.style.backgroundImage =
    `url('${imageList[Math.floor(Math.random()*imageList.length)]}')`;

  document.getElementById(areaId).appendChild(item);
}
